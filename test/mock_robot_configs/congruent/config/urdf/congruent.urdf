<?xml version="1.0"?>
<robot name="planar_arm">

  <link name="world" />

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="link_1"/>
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="link_1">
    <inertial>
      <origin xyz="0.0 0.0 20.0e-3" rpy="0 0 0" />
      <mass value="0.04401511" />
      <inertia ixx="13.84642e-6" ixy="0.0e-6"  ixz="0.0e-6"
                          iyy="13.84642e-6" iyz="-0.3556e-6"
                                     izz="15.95548e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_1.obj" />
      </geometry>
      <material name="grey_1">
        <color rgba="0.7 0.7 0.7 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_1.obj"  />
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.0 0.0 20.0e-3" rpy="0.0 0.0 0.0" />
    <axis xyz="0 0 1" />
    <!-- +/-3.106686 rad is +/-178 degrees -->
    <limit lower="-3.106686" upper="3.106686" effort="100.0" velocity="10.0" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

  <link name="link_2">
    <inertial>
      <origin xyz="150.0e-3 0.0e-3 0.0e-3" rpy="0 0 0" />
      <mass value="0.1211375" />
      <inertia ixx="13.36557e-6" ixy="0.0e-6"  ixz="0.0e-6"
                                iyy="946.62321e-6" iyz="0.0e-6"
                                          izz="951.91295e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_2.obj" />
      </geometry>
      <material name="grey_2">
        <color rgba="0.6 0.6 0.6 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_2.obj" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="300.0e-3 0.0 0.0" rpy="0.0 0.0 0.0" />
    <axis xyz="0 0 1" />
    <limit lower="-3.106686" upper="3.106686" effort="100.0" velocity="10.0" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

  <link name="link_3">
    <inertial>
      <origin xyz="150.0e-3 0.0e-3 0.0e-3" rpy="0 0 0" />
      <mass value="0.1211375" />
      <inertia ixx="13.36557e-6" ixy="0.0e-6"  ixz="0.0e-6"
                                iyy="946.62321e-6" iyz="0.0e-6"
                                          izz="951.91295e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_3.obj" />
      </geometry>
      <material name="grey_3">
        <color rgba="0.5 0.5 0.5 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_3.obj" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="300.0e-3 0.0 0.0" rpy="0.0 0.0 0.0" />
    <axis xyz="0 0 1" />
    <limit lower="-3.106686" upper="3.106686" effort="100.0" velocity="10.0" />
    <dynamics damping="0.0" friction="0.0" />
  </joint>

  <!-- The last link -->
  <link name="link_4">
    <inertial>
      <origin xyz="50.0e-3 0.0e-3 0.0e-3" rpy="0 0 0" />
      <mass value="0.04107782" />
      <inertia ixx="4.69244e-6" ixy="0.0e-6"  ixz="0.0e-6"
                                iyy="43.67283e-6" iyz="0.0e-6"
                                          izz="45.62675e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_4.obj" />
      </geometry>
      <material name="grey_4">
        <color rgba="0.4 0.4 0.4 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="./meshes/link_4.obj" />
      </geometry>
    </collision>
  </link>

  <!-- Dummy end effector link, basically on the sphere of the last link -->
  <link name="end_effector">
    <!-- Can be empty or have minimal visual marker -->
  </link>

  <!-- Fixed joint connecting link_4 to end effector -->
  <joint name="link_4_to_ee" type="fixed">
    <parent link="link_4"/>
    <child link="end_effector"/>
    <origin xyz="100.0e-3 0.0 0.0" rpy="0 0 0"/> 
  </joint>

</robot>